          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="false">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">def adjectives = [&quot;Global&quot;, &quot;Annual&quot;, &quot;Elite&quot;, &quot;International&quot;, &quot;Premier&quot;, &quot;NextGen&quot;, &quot;Future&quot;, &quot;Digital&quot;, &quot;Smart&quot;, &quot;Dynamic&quot;]
def eventTypes = [&quot;Summit&quot;, &quot;Conference&quot;, &quot;Workshop&quot;, &quot;Expo&quot;, &quot;Forum&quot;, &quot;Meetup&quot;, &quot;Championship&quot;, &quot;Tournament&quot;, &quot;Symposium&quot;]
def topics = [&quot;AI&quot;, &quot;Technology&quot;, &quot;Business&quot;, &quot;Innovation&quot;, &quot;Healthcare&quot;, &quot;Finance&quot;, &quot;Education&quot;, &quot;Startup&quot;, &quot;Marketing&quot;]

def rand = new java.util.Random()

def name = adjectives[rand.nextInt(adjectives.size())] + &quot; &quot; +
           topics[rand.nextInt(topics.size())] + &quot; &quot; +
           eventTypes[rand.nextInt(eventTypes.size())] + &quot; &quot; +
           rand.nextInt(1000)

vars.put(&quot;eventName&quot;, name)

// Debug
log.info(&quot;Generated Event Name: &quot; + name)</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
